# Optional: Add this to enable Gemini-powered chatbot answers.
# Without this key, the chatbot still works using local portfolio-data knowledge mode.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Alternative variable name used by some SDKs.
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# Optional: Model override for Gemini API.
GEMINI_MODEL=gemini-2.5-flash

# Optional: API base override.
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
